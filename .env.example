# Configuração de e-mail (SMTP)
# Exemplo com Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuemail@gmail.com
# SMTP_PASS=sua_app_password
# SMTP_FROM=noreply@solgreen.com.br
# SMTP_TO=andre@aex.partners

# Exemplo com Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=seuemail@outlook.com
# SMTP_PASS=sua_senha
# SMTP_FROM=noreply@solgreen.com.br
# SMTP_TO=contato@solgreen.com.br

# Exemplo com Mailgun:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@seudominio.mailgun.org
# SMTP_PASS=sua_api_key
# SMTP_FROM=noreply@solgreen.com.br
# SMTP_TO=contato@solgreen.com.br
