---
import { navLinks } from "../lib/data";
const currentPath = Astro.url.pathname;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<header class="fixed top-0 left-0 right-0 z-50" id="main-header">
  <nav class="bg-white/80 backdrop-blur-xl border-b border-neutral-200/60 transition-all duration-300" id="nav-bar">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2">
        <img src={`${base}img/logo-solgreen-energia.svg`} alt="SolGreen Energia" class="h-8" />
      </a>

      <!-- Desktop -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <li>
            <a
              href={`${base}${link.href.slice(1)}`}
              class:list={[
                "px-4 py-2 rounded-lg text-[13px] font-medium transition-all duration-200",
                currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                  ? "text-green bg-green/5"
                  : "text-neutral-500 hover:text-neutral-900 hover:bg-neutral-100",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href={`${base}contato`}
        class="hidden md:inline-flex items-center px-4 py-2 rounded-lg bg-neutral-900 text-white text-[13px] font-medium hover:bg-neutral-800 transition-colors"
      >
        Fale conosco
      </a>

      <!-- Mobile toggle -->
      <button class="md:hidden p-2" id="menu-toggle" aria-label="Menu">
        <svg class="w-5 h-5 text-neutral-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-5 h-5 text-neutral-700 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden hidden border-t border-neutral-100" id="mobile-menu">
      <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={`${base}${link.href.slice(1)}`}
            class:list={[
              "px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-green bg-green/5"
                : "text-neutral-600 hover:bg-neutral-50",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  toggle?.addEventListener("click", () => {
    const isHidden = menu?.classList.toggle("hidden") === false;
    menuIcon?.classList.toggle("hidden", isHidden);
    closeIcon?.classList.toggle("hidden", !isHidden);
  });
</script>
