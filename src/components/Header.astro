---
import { navLinks } from "../lib/data";
const currentPath = Astro.url.pathname;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<header class="fixed top-0 left-0 right-0 z-50" id="main-header">
  <nav class="bg-white/80 backdrop-blur-xl border-b border-neutral-200/60 transition-all duration-300" id="nav-bar">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
      <a href={base} class="flex items-center gap-2">
        <img src={`${base}img/logo-solgreen-energia.svg`} alt="SolGreen Energia" class="h-8" />
      </a>

      <!-- Desktop -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <li class={link.children ? "relative group flex items-center" : "flex items-center"}>
            {link.children ? (
              <>
                <button
                  class:list={[
                    "px-4 py-2 rounded-lg text-[13px] font-medium transition-all duration-200 inline-flex items-center gap-1 leading-none",
                    currentPath.startsWith(link.href) || currentPath.startsWith("/simulador") || currentPath.startsWith("/recursos")
                      ? "text-green bg-green/5"
                      : "text-neutral-500 hover:text-neutral-900 hover:bg-neutral-100",
                  ]}
                >
                  {link.label}
                  <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                  <div class="bg-white rounded-xl border border-neutral-200 shadow-lg py-2 min-w-[220px]">
                    {link.children.map((child) => (
                      <a
                        href={`${base}${child.href.slice(1)}`}
                        class:list={[
                          "block px-4 py-2.5 text-[13px] font-medium transition-colors",
                          currentPath === child.href || currentPath.startsWith(child.href)
                            ? "text-green bg-green/5"
                            : "text-neutral-500 hover:text-neutral-900 hover:bg-neutral-50",
                        ]}
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={`${base}${link.href.slice(1)}`}
                class:list={[
                  "px-4 py-2 rounded-lg text-[13px] font-medium transition-all duration-200",
                  currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                    ? "text-green bg-green/5"
                    : "text-neutral-500 hover:text-neutral-900 hover:bg-neutral-100",
                ]}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>

      <a
        href={`${base}contato`}
        class="hidden md:inline-flex items-center px-4 py-2 rounded-lg bg-neutral-900 text-white text-[13px] font-medium hover:bg-neutral-800 transition-colors"
      >
        Fale conosco
      </a>

      <!-- Mobile toggle -->
      <button class="md:hidden p-2" id="menu-toggle" aria-label="Menu">
        <svg class="w-5 h-5 text-neutral-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-5 h-5 text-neutral-700 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div class="md:hidden hidden border-t border-neutral-100" id="mobile-menu">
      <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
        {navLinks.map((link) => (
          link.children ? (
            <>
              <p class="px-3 py-2 text-xs font-semibold text-neutral-400 uppercase tracking-widest mt-2">{link.label}</p>
              {link.children.map((child) => (
                <a
                  href={`${base}${child.href.slice(1)}`}
                  class:list={[
                    "px-3 py-2.5 rounded-lg text-sm font-medium transition-colors pl-6",
                    currentPath === child.href || currentPath.startsWith(child.href)
                      ? "text-green bg-green/5"
                      : "text-neutral-600 hover:bg-neutral-50",
                  ]}
                >
                  {child.label}
                </a>
              ))}
            </>
          ) : (
            <a
              href={`${base}${link.href.slice(1)}`}
              class:list={[
                "px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
                currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                  ? "text-green bg-green/5"
                  : "text-neutral-600 hover:bg-neutral-50",
              ]}
            >
              {link.label}
            </a>
          )
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  toggle?.addEventListener("click", () => {
    const isHidden = menu?.classList.toggle("hidden") === false;
    menuIcon?.classList.toggle("hidden", isHidden);
    closeIcon?.classList.toggle("hidden", !isHidden);
  });
</script>
