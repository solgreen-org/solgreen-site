---
import Layout from "../../layouts/Layout.astro";
import { ContactForm } from "../../components/sections/ContactForm";
import { sectors } from "../../lib/data";

export function getStaticPaths() {
  return sectors.map((s) => ({
    params: { slug: s.slug },
    props: { sector: s },
  }));
}

const { sector } = Astro.props;
const otherSectors = sectors.filter((s) => s.slug !== sector.slug).slice(0, 3);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<Layout title={sector.title} description={sector.description}>
  <!-- Split assimétrico: texto esquerda, foto vívida direita -->
  <section class="bg-neutral-50 border-b border-neutral-200">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 items-center">
        <div class="py-12 lg:py-16 lg:pr-12">
          <p class="text-xs font-semibold text-green uppercase tracking-widest mb-3">Setores</p>
          <h1 class="text-3xl md:text-4xl font-heading font-bold text-neutral-900 tracking-tight mb-4">{sector.title}</h1>
          <p class="text-neutral-500 leading-relaxed">{sector.description}</p>
        </div>
        <div class="relative h-64 lg:h-80 rounded-2xl lg:rounded-none lg:rounded-l-2xl overflow-hidden mb-6 lg:mb-0">
          <img src={`${base}${sector.cover.slice(1)}`} alt={sector.title} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          {sector.pain && (
            <div class="rounded-xl bg-red-50 border border-red-100 p-6 mb-8">
              <p class="text-xs font-semibold text-red-400 uppercase tracking-widest mb-2">O risco real</p>
              <p class="text-red-700 font-medium">{sector.pain}</p>
            </div>
          )}

          <p class="text-lg text-neutral-500 leading-relaxed mb-8">{sector.description}</p>

          <div class="pt-8 border-t border-neutral-200">
            <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">O que oferecemos para este setor</p>
            <ul class="flex flex-col gap-4">
              {sector.solutions.map((sol) => (
                <li class="flex items-start gap-3 p-4 rounded-xl bg-neutral-50 border border-neutral-100">
                  <svg class="w-5 h-5 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-neutral-600">{sol}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24 rounded-xl border border-neutral-200 p-6">
            <ContactForm
              client:visible
              title="Falar com engenheiro"
              showConsumption={false}
            />
          </div>
        </div>
      </div>

      <div class="mt-16 pt-10 border-t border-neutral-200">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-6">Outros setores</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {otherSectors.map((s) => (
            <a
              href={`${base}setores/${s.slug}`}
              class="group flex items-center gap-4 p-4 rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-sm transition-all"
            >
              <div class="w-10 h-10 rounded-lg bg-green/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.icon} />
                </svg>
              </div>
              <span class="font-medium text-neutral-900 text-sm group-hover:text-green transition-colors">{s.title}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
