---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import { sectors } from "../../lib/data";
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<Layout title="Setores" description="Soluções de energia por segmento: avicultura, agro, câmaras frias, geradoras e comércio.">
  <PageHeader
    title="Setores que atendemos"
    subtitle="Cada operação tem uma dor diferente. Entendemos a sua e dimensionamos a solução certa."
  />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {sectors.map((s) => (
          <a
            href={`${base}setores/${s.slug}`}
            class="group block rounded-xl border border-neutral-200 bg-white p-8 hover:border-green/30 hover:shadow-sm transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-xl bg-green/10 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.icon} />
              </svg>
            </div>
            <h2 class="font-heading font-bold text-neutral-900 text-lg mb-2 group-hover:text-green transition-colors">{s.title}</h2>
            <p class="text-xs text-red-500/80 font-medium mb-3">{s.pain}</p>
            <p class="text-sm text-neutral-400 leading-relaxed mb-4">{s.description}</p>
            {s.stats.investment && (
              <p class="text-xs text-neutral-500 mb-4">
                Investimento a partir de <span class="font-semibold text-neutral-700">{s.stats.investment}</span>
              </p>
            )}
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-400 group-hover:text-green transition-colors">
              Ver soluções
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
