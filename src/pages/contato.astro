---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { ContactForm } from "../components/sections/ContactForm";
import { contact } from "../lib/data";
---

<Layout title="Contato" description="Entre em contato com a SolGreen Energia. Solicite um orçamento para seu projeto de energia solar ou engenharia elétrica.">
  <PageHeader title="Fale conosco" subtitle="Ficou com alguma dúvida? Quer simular seu projeto conosco?" />

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <ContactForm client:visible title="" subtitle="" />
        </div>

        <div>
          <div class="rounded-xl border border-neutral-200 p-6">
            <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-5">Informações</p>

            <div class="flex flex-col gap-5">
              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-neutral-100 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <p class="text-sm text-neutral-900 font-medium">Endereço</p>
                  <p class="text-sm text-neutral-400 mt-0.5">{contact.address}<br/>{contact.neighborhood}<br/>{contact.city}</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-neutral-100 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div>
                  <p class="text-sm text-neutral-900 font-medium">Telefone</p>
                  <a href={contact.phoneLink} class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors block mt-0.5">{contact.phone}</a>
                  <a href={contact.whatsappLink} class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors block">{contact.whatsapp}</a>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-neutral-100 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <p class="text-sm text-neutral-900 font-medium">E-mail</p>
                  <a href={`mailto:${contact.email}`} class="text-sm text-neutral-400 hover:text-neutral-900 transition-colors block mt-0.5">{contact.email}</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 rounded-xl overflow-hidden h-72 border border-neutral-200">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1752.0!2d-53.5170!3d-28.2930!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94fdcab0a0a0a0a1%3A0x1!2sAv.+dos+Imigrantes%2C+1351+-+Distrito+Industrial%2C+Panambi+-+RS!5e0!3m2!1spt-BR!2sbr!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          title="Localização SolGreen Energia"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
