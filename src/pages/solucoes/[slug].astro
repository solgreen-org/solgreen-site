---
import Layout from "../../layouts/Layout.astro";
import { ContactForm } from "../../components/sections/ContactForm";
import { pillars } from "../../lib/data";

export function getStaticPaths() {
  return pillars.map((p) => ({
    params: { slug: p.slug },
    props: { pillar: p },
  }));
}

const { pillar } = Astro.props;
const otherPillars = pillars.filter((p) => p.slug !== pillar.slug);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const contentMap: Record<string, { intro: string; details: string[]; benefits: string[] }> = {
  "usinas-solares": {
    intro: "Projetamos e construímos usinas fotovoltaicas de solo. EPC completo, da simulação ao comissionamento.",
    details: [
      "Nossa equipe já entregou mais de 30 MWp em usinas solares. Atuamos desde o estudo de viabilidade e simulação de produção até a construção, conexão à rede e start-up.",
      "A experiência de 20 anos em engenharia elétrica industrial, incluindo subestações e sistemas de média tensão, nos diferencia de integradores que só conhecem baixa tensão.",
    ],
    benefits: [
      "Projeto e construção EPC completo",
      "Simulação de produção energética",
      "Aprovação e conexão junto à distribuidora",
      "Comissionamento e start-up",
      "Engenharia de subestação e média tensão incluída",
      "Experiência real: +30 MWp entregues",
    ],
  },
  "armazenamento": {
    intro: "Sistemas de armazenamento de energia com baterias de lítio que respondem em milissegundos. Substituem ou complementam o gerador diesel com zero manutenção e 10+ anos de vida útil.",
    details: [
      "A bateria de lítio responde em milissegundos. Não existe gap de energia como nos geradores diesel que levam 10 a 30 segundos para ligar. Para avicultura, câmaras frias e operações críticas, essa diferença pode valer R$ 150 mil em produto salvo.",
      "Oferecemos duas abordagens: substituição do gerador diesel (para quem não tem) e complemento ao gerador (para quem já tem mas precisa eliminar o gap de transição e ter redundância).",
      "Os sistemas que trabalhamos têm 10+ anos de garantia, 6.000 a 8.000 ciclos de vida útil e manutenção praticamente zero. O custo por kWh armazenado já está competitivo com gerador diesel quando se considera combustível e manutenção ao longo de 10 anos.",
    ],
    benefits: [
      "Resposta instantânea (milissegundos)",
      "Substitui ou complementa gerador diesel",
      "Zero manutenção, sem combustível",
      "Garantia de 10+ anos",
      "Integração com solar (carrega durante o dia)",
      "Monitoramento remoto e alertas",
    ],
  },
  "automacao-energetica": {
    intro: "Monitoramento de consumo em tempo real, gestão de demanda contratada, controle inteligente de equipamentos e alertas automáticos. Tudo acessível pelo celular.",
    details: [
      "Muitas operações gastam mais energia do que precisam simplesmente porque não medem, não monitoram e não controlam. Um armazém de grãos com secador pode reduzir 15-30% do consumo com automação de aeração e gestão de horários de operação.",
      "Nossos sistemas de automação energética integram sensores de temperatura, umidade, consumo e demanda com dashboards acessíveis pelo celular. Você sabe exatamente quanto está gastando, onde e por quê.",
      "Para granjas, a automação vai além da energia: controle de ventilação, comedouros, iluminação e cortinas, tudo integrado com backup por bateria para que uma queda de energia não signifique perda de produção.",
    ],
    benefits: [
      "Dashboard de consumo em tempo real",
      "Alertas de falha e consumo anormal",
      "Automação de ventilação, iluminação e motores",
      "Gestão de demanda contratada",
      "Integração com baterias e solar",
      "Acesso remoto via celular",
    ],
  },
};

const content = contentMap[pillar.slug] || contentMap["usinas-solares"];
const isUsina = pillar.slug === "usinas-solares";
---

<Layout title={pillar.title} description={pillar.description}>
  <!-- Estilo editorial: texto limpo + foto vívida abaixo -->
  <section class="pt-12 pb-0">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-semibold text-green uppercase tracking-widest mb-3">Soluções</p>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-neutral-900 tracking-tight mb-4">{pillar.title}</h1>
      <p class="text-neutral-500 max-w-2xl mb-8">{pillar.description}</p>
    </div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="rounded-2xl overflow-hidden">
        <img src={`${base}${pillar.cover.slice(1)}`} alt={pillar.title} class="w-full h-56 md:h-80 object-cover" />
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <p class="text-lg text-neutral-500 leading-relaxed mb-8">{content.intro}</p>

          {content.details.map((p) => (
            <p class="text-neutral-600 leading-relaxed mb-4">{p}</p>
          ))}

          <div class="mt-10 pt-8 border-t border-neutral-200">
            <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">O que entregamos</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {content.benefits.map((b) => (
                <li class="flex items-start gap-2.5">
                  <svg class="w-4 h-4 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-neutral-600">{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24 rounded-xl border border-neutral-200 p-6">
            <ContactForm
              client:visible
              title="Falar com engenheiro"
              showConsumption={isUsina}
            />
          </div>
        </div>
      </div>

      <div class="mt-16 pt-10 border-t border-neutral-200">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-6">Outras soluções</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {otherPillars.map((p) => (
            <a
              href={`${base}solucoes/${p.slug}`}
              class="group flex items-center gap-4 p-4 rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-sm transition-all"
            >
              <div class="w-10 h-10 rounded-lg bg-green/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={p.icon as string} />
                </svg>
              </div>
              <div>
                <span class="font-medium text-neutral-900 text-sm group-hover:text-green transition-colors">{p.title}</span>
                <p class="text-xs text-neutral-400 mt-0.5">{p.description.slice(0, 80)}...</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
