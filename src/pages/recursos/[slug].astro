---
import Layout from "../../layouts/Layout.astro";

export const prerender = true;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allFiles = import.meta.glob("../../content/artigos/*.md", { eager: true }) as Record<string, any>;
const articles = Object.values(allFiles);

export function getStaticPaths() {
  const allFiles = import.meta.glob("../../content/artigos/*.md", { eager: true }) as Record<string, any>;
  return Object.entries(allFiles).map(([path, article]) => ({
    params: { slug: path.split("/").pop()?.replace(".md", "") },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = article;
const { title, description, image, category, tags } = article.frontmatter;

const otherArticles = articles
  .filter((a: any) => a.frontmatter.title !== title)
  .slice(0, 3);
---

<Layout title={title} description={description}>
  <section class="pt-12 pb-0">
    <div class="max-w-6xl mx-auto px-6">
      <a href={`${base}recursos`} class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-400 hover:text-green transition-colors mb-6">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Voltar para Recursos
      </a>
      <p class="text-xs font-semibold text-green uppercase tracking-widest mb-3">{category}</p>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-neutral-900 tracking-tight mb-4">{title}</h1>
      <p class="text-neutral-500 max-w-3xl mb-8">{description}</p>
    </div>
    {image && (
      <div class="max-w-6xl mx-auto px-6">
        <div class="rounded-2xl overflow-hidden">
          <img src={`${base}${image.slice(1)}`} alt={title} class="w-full h-56 md:h-80 object-cover" />
        </div>
      </div>
    )}
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 prose prose-neutral prose-headings:font-heading prose-headings:font-bold prose-a:text-green max-w-none">
          <Content />
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24">
            {tags && tags.length > 0 && (
              <div class="mb-8">
                <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-3">Tags</p>
                <div class="flex flex-wrap gap-2">
                  {tags.map((tag: string) => (
                    <span class="px-3 py-1 rounded-full bg-neutral-100 text-xs text-neutral-500">{tag}</span>
                  ))}
                </div>
              </div>
            )}

            <div class="rounded-xl border border-neutral-200 p-6">
              <p class="font-heading font-bold text-neutral-900 mb-2">Quer proteger sua operação?</p>
              <p class="text-sm text-neutral-400 mb-4">Fale com nossos engenheiros e descubra a melhor solução para o seu negócio.</p>
              <a href={`${base}contato`} class="block text-center px-4 py-2.5 rounded-lg bg-neutral-900 text-white text-sm font-medium hover:bg-neutral-800 transition-colors">
                Falar com engenheiro
              </a>
              <a href={`${base}simulador`} class="block text-center px-4 py-2.5 rounded-lg border border-neutral-200 text-neutral-600 text-sm font-medium hover:bg-neutral-50 transition-colors mt-2">
                Simular risco energético
              </a>
            </div>
          </div>
        </div>
      </div>

      {otherArticles.length > 0 && (
        <div class="mt-16 pt-10 border-t border-neutral-200">
          <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-6">Outros artigos</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {otherArticles.map((a: any) => {
              const s = Object.entries(allFiles).find(([_, v]) => v === a)?.[0]?.split("/").pop()?.replace(".md", "");
              return (
                <a href={`${base}recursos/${s}`} class="group p-4 rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-sm transition-all">
                  <p class="text-xs text-green font-medium mb-1">{a.frontmatter.category}</p>
                  <p class="font-medium text-neutral-900 text-sm group-hover:text-green transition-colors">{a.frontmatter.title}</p>
                </a>
              );
            })}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
