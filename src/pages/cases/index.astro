---
import Layout from "../../layouts/Layout.astro";
import { cases } from "../../lib/data";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const [featured, ...rest] = cases;
---

<Layout title="Cases" description="Conheça as usinas solares projetadas e construídas pela SolGreen Energia em diversas regiões do Brasil.">
  <!-- Hero -->
  <section class="pt-20 pb-12">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-semibold text-green uppercase tracking-widest mb-3">Portfólio</p>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-neutral-900 tracking-tight mb-4">Usinas que projetamos e construímos</h1>
      <p class="text-neutral-500 max-w-2xl text-lg leading-relaxed">
        Alguns dos projetos que executamos, da engenharia ao comissionamento: do estudo de viabilidade à conexão com a rede.
      </p>
    </div>
  </section>

  <!-- Featured case -->
  <section class="pb-8">
    <div class="max-w-6xl mx-auto px-6">
      <a href={`${base}cases/${featured.slug}`} class="group block rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-md transition-all overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="h-64 md:h-full overflow-hidden">
            <img
              src={`${base}${featured.cover.slice(1)}`}
              alt={featured.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 md:p-10 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-4">
              <span class="px-2.5 py-1 rounded-full bg-green/10 text-green text-xs font-medium">{featured.power}</span>
              <span class="px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-500 text-xs font-medium">{featured.modality}</span>
            </div>
            <h2 class="font-heading font-bold text-neutral-900 text-2xl md:text-3xl group-hover:text-green transition-colors mb-2">{featured.title}</h2>
            <p class="text-sm text-neutral-400 mb-4">{featured.location} · {featured.client}</p>
            <p class="text-neutral-500 leading-relaxed mb-6">{featured.challenge}</p>
            <div class="flex flex-wrap gap-4 text-xs text-neutral-400">
              {featured.specs.slice(0, 2).map((spec: string) => (
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {spec}
                </span>
              ))}
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Other cases -->
  <section class="py-8 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {rest.map((c) => (
          <a href={`${base}cases/${c.slug}`} class="group rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-sm transition-all overflow-hidden">
            <div class="h-48 overflow-hidden">
              <img
                src={`${base}${c.cover.slice(1)}`}
                alt={c.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="px-2.5 py-1 rounded-full bg-green/10 text-green text-xs font-medium">{c.power}</span>
                <span class="px-2.5 py-1 rounded-full bg-neutral-100 text-neutral-500 text-xs font-medium">{c.modality}</span>
              </div>
              <h2 class="font-heading font-bold text-neutral-900 text-lg group-hover:text-green transition-colors mb-1">{c.title}</h2>
              <p class="text-xs text-neutral-400 mb-3">{c.location} · {c.client}</p>
              <p class="text-sm text-neutral-500 leading-relaxed">{c.challenge}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
