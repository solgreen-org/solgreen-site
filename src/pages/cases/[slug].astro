---
import Layout from "../../layouts/Layout.astro";
import { cases } from "../../lib/data";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

export function getStaticPaths() {
  return cases.map((c) => ({
    params: { slug: c.slug },
    props: { caseData: c },
  }));
}

const { caseData } = Astro.props;
const otherCases = cases.filter((c) => c.slug !== caseData.slug);
---

<Layout title={caseData.title} description={`Usina solar ${caseData.title} - ${caseData.power} em ${caseData.location}. Construída pela SolGreen Energia.`}>
  <section class="pt-12 pb-0">
    <div class="max-w-6xl mx-auto px-6">
      <a href={`${base}cases`} class="inline-flex items-center gap-1.5 text-xs font-medium text-neutral-400 hover:text-green transition-colors mb-6">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Voltar para Cases
      </a>
      <p class="text-xs font-semibold text-green uppercase tracking-widest mb-3">{caseData.power} · {caseData.modality}</p>
      <h1 class="text-3xl md:text-5xl font-heading font-bold text-neutral-900 tracking-tight mb-4">{caseData.title}</h1>
      <p class="text-neutral-500 mb-8">{caseData.location} · Cliente: {caseData.client}</p>
    </div>
    <div class="max-w-6xl mx-auto px-6">
      <div class="rounded-2xl overflow-hidden">
        <img src={`${base}${caseData.cover.slice(1)}`} alt={caseData.title} class="w-full h-56 md:h-96 object-cover" />
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <div class="mb-10">
            <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">Desafio</p>
            <p class="text-lg text-neutral-600 leading-relaxed">{caseData.challenge}</p>
          </div>

          {caseData.scope && (
            <div class="mb-10">
              <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">Escopo do projeto</p>
              <p class="text-neutral-600 leading-relaxed">{caseData.scope}</p>
            </div>
          )}

          {caseData.highlights && caseData.highlights.length > 0 && (
            <div class="mb-10">
              <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">Destaques</p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {caseData.highlights.map((h: string) => (
                  <li class="flex items-start gap-2.5">
                    <svg class="w-4 h-4 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm text-neutral-600">{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {caseData.photos.length > 0 && (
            <div class="mb-10">
              <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">Galeria</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {caseData.photos.map((photo: string, i: number) => (
                  <div class="rounded-xl overflow-hidden">
                    <img src={`${base}${photo.slice(1)}`} alt={`${caseData.title} - Foto ${i + 1}`} class="w-full h-48 md:h-64 object-cover" />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        <div class="lg:col-span-1">
          <div class="sticky top-24">
            <div class="rounded-xl border border-neutral-200 p-6 mb-6">
              <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-4">Ficha técnica</p>

              <div class="flex flex-col gap-4">
                <div>
                  <p class="text-xs text-neutral-400">Potência</p>
                  <p class="text-sm font-medium text-neutral-900">{caseData.power}</p>
                </div>
                <div>
                  <p class="text-xs text-neutral-400">Modalidade</p>
                  <p class="text-sm font-medium text-neutral-900">{caseData.modality}</p>
                </div>
                <div>
                  <p class="text-xs text-neutral-400">Localização</p>
                  <p class="text-sm font-medium text-neutral-900">{caseData.location}</p>
                </div>
                <div>
                  <p class="text-xs text-neutral-400">Cliente</p>
                  <p class="text-sm font-medium text-neutral-900">{caseData.client}</p>
                </div>
              </div>

              <div class="mt-6 pt-4 border-t border-neutral-200">
                <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-3">Componentes</p>
                <ul class="flex flex-col gap-2">
                  {caseData.specs.map((spec: string) => (
                    <li class="flex items-start gap-2">
                      <svg class="w-4 h-4 text-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-xs text-neutral-600">{spec}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="rounded-xl border border-neutral-200 p-6">
              <p class="font-heading font-bold text-neutral-900 mb-2">Quer um projeto como este?</p>
              <p class="text-sm text-neutral-400 mb-4">Fale com nossos engenheiros sobre o seu projeto de usina solar.</p>
              <a href={`${base}contato`} class="block text-center px-4 py-2.5 rounded-lg bg-neutral-900 text-white text-sm font-medium hover:bg-neutral-800 transition-colors">
                Falar com engenheiro
              </a>
            </div>
          </div>
        </div>
      </div>

      {otherCases.length > 0 && (
        <div class="mt-16 pt-10 border-t border-neutral-200">
          <p class="text-xs font-semibold text-neutral-400 uppercase tracking-widest mb-6">Outros cases</p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {otherCases.slice(0, 3).map((c) => (
              <a href={`${base}cases/${c.slug}`} class="group rounded-xl border border-neutral-200 hover:border-neutral-300 hover:shadow-sm transition-all overflow-hidden">
                <div class="h-32 overflow-hidden">
                  <img src={`${base}${c.cover.slice(1)}`} alt={c.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-4">
                  <span class="text-xs text-green font-medium">{c.power}</span>
                  <p class="font-medium text-neutral-900 text-sm group-hover:text-green transition-colors mt-1">{c.title}</p>
                  <p class="text-xs text-neutral-400">{c.location}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
