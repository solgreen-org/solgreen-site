---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
const {
  title,
  description = "Energia inteligente para operações que não podem errar. Usinas solares, armazenamento por bateria e automação energética.",
  image = "/img/share.jpg",
} = Astro.props;

const fullTitle = title === "Home"
  ? "SolGreen Energia - Usinas Solares, Armazenamento e Automação Energética"
  : `${title} - SolGreen Energia`;
const canonicalUrl = new URL(Astro.url.pathname, "https://solgreen.com.br");
const absoluteImage = image.startsWith("http")
  ? image
  : new URL(image, "https://solgreen.com.br").toString();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#22c55e" />

    <link rel="apple-touch-icon" sizes="180x180" href={`${base}favicons/apple-touch-icon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicons/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicons/favicon-16x16.png`} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SolGreen Energia" />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
